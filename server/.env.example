# Database — use RDS endpoint in production, localhost for local dev
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=devtool

# Auth
SECRET_KEY=                # openssl rand -hex 32
FERNET_KEY=                # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Sync endpoint secret (EventBridge Scheduler sends this in X-Sync-Secret header)
SYNC_SECRET=               # openssl rand -hex 32

# CORS — comma-separated list of allowed origins, no trailing slash
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

ENVIRONMENT=development    # development | staging | production

# Lokamspace environments — base URLs are defaulted, only API keys need to be set
APP_BASE_URL=https://api.app.lokam.ai
APP_API_KEY=               # internal API key for calls-export / bugs-export endpoints

ARENA_BASE_URL=https://api.arena.lokam.ai
ARENA_API_KEY=

PLAYGROUND_BASE_URL=https://api.playground.lokam.ai
PLAYGROUND_API_KEY=
